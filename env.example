# ---- Local development ----
# NEXT_PUBLIC_BE_URL=http://localhost:5000
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-secret-at-least-32-chars

# ---- Production (EC2 / PM2) ----
# Build MUST be run with NEXT_PUBLIC_BE_URL set (Next.js inlines it at build time):
#   NEXT_PUBLIC_BE_URL=https://backend.editdeckpro.com npm run build
# At runtime, set the public URL of this frontend (required for auth redirects/cookies):
NEXT_PUBLIC_BE_URL=https://backend.editdeckpro.com
NEXTAUTH_URL=https://app.editdeckpro.com
NEXTAUTH_SECRET=0d4eeb48408762e3f4d789cf921d4161
# When behind nginx/reverse proxy so NextAuth trusts X-Forwarded-Host/Proto:
AUTH_TRUST_HOST=true